{
  "name": "mygiulia-logs-viewer",
  "version": "1.0.0",
  "type": "module",
  "description": "Browser-based Telemetry Log Viewer for Alfa Romeo (Angular rewrite in progress)",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format": "prettier --write .",
    "check": "prettier --check .",
    "legacy:dev": "vite --config legacy/vite.config.mjs",
    "legacy:test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config legacy/jest.config.js",
    "legacy:test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config legacy/jest.config.js --coverage"
  },
  "author": "Tomasz Żebrowski",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "date-fns": "^4.1.0",
    "hammerjs": "^2.0.8",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.0",
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@eslint/js": "^9.39.2",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@types/hammerjs": "^2.0.46",
    "@types/leaflet": "^1.9.20",
    "babel-jest": "^30.2.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "babel-plugin-transform-vite-meta-env": "^1.0.3",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^28.0.0",
    "postcss-csso": "^6.0.1",
    "postcss-preset-env": "^11.1.3",
    "prettier": "^3.8.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.8"
  }
}
